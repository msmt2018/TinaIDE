# Copy this file to `keystore.properties` for local release signing.
# Do not commit the real `keystore.properties`.

storeFile=keystore/release.jks
storePassword=CHANGE_ME
keyAlias=tinaide
keyPassword=CHANGE_ME

# Optional runtime secrets.
# For local development you can fill them here.
# For GitHub Actions release builds, use repository secrets instead.
SERVER_CONFIG_HMAC_SECRET=
