+
+static bool isAndroidExecTraceEnabled() {
+  if (const char *Trace = std::getenv("TINAIDE_LLVM_EXEC_TRACE"))
+    return Trace[0] != '\0' && strcmp(Trace, "0") != 0;
+  return TINAIDE_LLVM_EXEC_TRACE_DEFAULT != 0;
+}
+
+static int getAndroidSdkVersion() {
+  char SdkVersion[PROP_VALUE_MAX];
+  if (__system_property_get("ro.build.version.sdk", SdkVersion) <= 0)
+    return 0;
+  char *End = nullptr;
+  long Value = std::strtol(SdkVersion, &End, 10);
+  if (End == SdkVersion || Value <= 0)
+    return 0;
+  return static_cast<int>(Value);
+}
+
+static bool shouldWrapAndroidExecWithLinker() {
+  if (const char *Override = std::getenv("TINAIDE_LLVM_WRAP_EXEC_LINKER64"))
+    return Override[0] != '\0' && strcmp(Override, "0") != 0 &&
+           strcmp(Override, "false") != 0 && strcmp(Override, "disable") != 0;
+  return getAndroidSdkVersion() >= 29;
+}
+
+static bool isAndroidLinkerProgram(StringRef ProgramPath) {
+  StringRef FileName = sys::path::filename(ProgramPath);
+  return FileName == "linker" || FileName == "linker64";
+}
+
+static StringRef resolveAndroidLinkerPath() {
+  static const char *Candidates[] = {
+      "/system/bin/linker64",
+      "/apex/com.android.runtime/bin/linker64",
+      "/system/bin/linker",
+      "/apex/com.android.runtime/bin/linker"};
+  for (const char *Path : Candidates) {
+    if (::access(Path, X_OK) == 0)
+      return StringRef(Path);
+  }
+  return StringRef();
+}
+
+static void maybeWrapWithAndroidLinker(StringRef &Program, ArrayRef<StringRef> &Args,
+                                       SmallVectorImpl<StringRef> &WrappedArgsStorage) {
+  if (!shouldWrapAndroidExecWithLinker()) {
+    if (isAndroidExecTraceEnabled()) {
+      errs() << "[TinaIDE][Program.inc] skip wrap: linker64 disabled, sdk="
+             << getAndroidSdkVersion() << " for " << Program << "\n";
+    }
+    return;
+  }
+  if (Program.empty() || !Program.starts_with('/'))
+    return;
+  if (isAndroidLinkerProgram(Program))
+    return;
+
+  StringRef Linker = resolveAndroidLinkerPath();
+  if (Linker.empty()) {
+    if (isAndroidExecTraceEnabled()) {
+      errs() << "[TinaIDE][Program.inc] skip wrap: linker64 not found for "
+             << Program << "\n";
+    }
+    return;
+  }
+
+  const bool FirstArgIsTarget = !Args.empty() && Args.front() == Program;
+  WrappedArgsStorage.clear();
+  WrappedArgsStorage.reserve(Args.size() + 2);
+  // linker64 argv 约定：
+  // argv[0] = linker64 本身
+  // argv[1] = 目标 ELF 的绝对路径
+  WrappedArgsStorage.push_back(Linker);
+  WrappedArgsStorage.push_back(Program);
+  if (FirstArgIsTarget) {
+    WrappedArgsStorage.append(Args.begin() + 1, Args.end());
+  } else {
+    WrappedArgsStorage.append(Args.begin(), Args.end());
+  }
+  Args = WrappedArgsStorage;
+
+  if (isAndroidExecTraceEnabled()) {
+    errs() << "[TinaIDE][Program.inc] wrap exec via linker64: "
+           << Program << " -> " << Linker
+           << ", argc=" << Args.size()
+           << ", argv0=" << (Args.empty() ? StringRef("(empty)") : Args[0])
+           << ", argv1="
+           << (Args.size() > 1 ? Args[1] : StringRef("(missing)"))
+           << "\n";
+  }
+  Program = Linker;
+}
