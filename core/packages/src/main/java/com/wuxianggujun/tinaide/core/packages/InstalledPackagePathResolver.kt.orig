package com.wuxianggujun.tinaide.core.packages

import android.content.Context
import java.io.File
import timber.log.Timber

/**
 * 扫描已安装的 Download 类型包，收集 include / lib 路径。
 *
 * 约定：包解压后若包含 `include/` 子目录，则视为可提供头文件；
 * 若包含 `lib/` 子目录，则视为可提供库文件。
 */
object InstalledPackagePathResolver {

    private const val TAG = "PkgPathResolver"
    private const val INSTALL_DIR_NAME = "installed-packages"

    data class PackagePaths(
        /** 所有已安装包中存在的 include 目录 */
        val includeDirs: List<File>,
        /** 所有已安装包中存在的 lib 目录 */
        val libDirs: List<File>,
        /** 包根目录列表（供 CMAKE_PREFIX_PATH 使用） */
        val prefixDirs: List<File>
    ) {
        val isEmpty: Boolean get() = includeDirs.isEmpty() && libDirs.isEmpty()
    }

    /**
     * 扫描 installed-packages 目录，返回所有有效的 include/lib 路径。
     */
    fun resolve(context: Context): PackagePaths {
        val installDir = File(context.filesDir, INSTALL_DIR_NAME)
        if (!installDir.isDirectory) {
            return PackagePaths(emptyList(), emptyList(), emptyList())
        }

        val includeDirs = mutableListOf<File>()
        val libDirs = mutableListOf<File>()
        val prefixDirs = mutableListOf<File>()

        val packageDirs = installDir.listFiles { f -> f.isDirectory } ?: return PackagePaths(emptyList(), emptyList(), emptyList())

        for (pkgDir in packageDirs) {
            val includeDir = File(pkgDir, "include")
            val libDir = File(pkgDir, "lib")

            if (includeDir.isDirectory || libDir.isDirectory) {
                prefixDirs.add(pkgDir)
            }
            if (includeDir.isDirectory) {
                includeDirs.add(includeDir)
            }
            if (libDir.isDirectory) {
                libDirs.add(libDir)
            }
        }

        Timber.tag(TAG).d(
            "Resolved %d include dirs, %d lib dirs from %d packages",
            includeDirs.size, libDirs.size, packageDirs.size
        )
        return PackagePaths(includeDirs, libDirs, prefixDirs)
    }
}
