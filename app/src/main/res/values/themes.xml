<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - Fixed Dark Theme -->
    <style name="Base.Theme.TinaIDE" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/dark_primary</item>
        <item name="colorPrimaryVariant">@color/dark_primary_variant</item>
        <item name="colorOnPrimary">@color/dark_on_primary</item>
        
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/dark_secondary</item>
        <item name="colorOnSecondary">@color/dark_on_secondary</item>
        
        <!-- Background colors -->
        <item name="android:colorBackground">@color/dark_background</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnBackground">@color/dark_on_background</item>
        <item name="colorOnSurface">@color/dark_on_surface</item>
        
        <!-- Error color -->
        <item name="colorError">@color/dark_error</item>
        <item name="colorOnError">@color/dark_on_error</item>
        
        <!-- Status bar and navigation bar -->
        <item name="android:statusBarColor">@color/dark_primary</item>
        <item name="android:navigationBarColor">@color/dark_background</item>
        
        <!-- Window background -->
        <item name="android:windowBackground">@color/dark_background</item>
    </style>

    <style name="Theme.TinaIDE" parent="Base.Theme.TinaIDE" />

    <!-- Dark popup menu for Toolbar overflow with readable contrast -->
    <style name="ThemeOverlay.Tina.ToolbarPopup.Dark" parent="ThemeOverlay.AppCompat.Dark">
        <item name="popupMenuStyle">@style/Widget.Tina.PopupMenu.Dark</item>
        <item name="android:popupMenuStyle">@style/Widget.Tina.PopupMenu.Dark</item>
    </style>

    <style name="Widget.Tina.PopupMenu.Dark" parent="Widget.AppCompat.PopupMenu">
        <item name="android:popupBackground">@android:color/black</item>
        <item name="android:itemTextAppearance">@style/TextAppearance.Tina.PopupMenuItem</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="TextAppearance.Tina.PopupMenuItem" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textColor">@android:color/white</item>
    </style>
</resources>
