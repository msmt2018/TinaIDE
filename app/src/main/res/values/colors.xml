    <color name="md_theme_surfaceContainerHigh">#E8EAE8</color>
    <color name="md_theme_surfaceContainerHighest">#E2E4E2</color>

    <!-- ========== 应用特定颜色（浅色模式） ========== -->

    <!-- 状态栏和导航栏 -->
    <color name="statusBarColor">#FAFDFB</color>
    <color name="navigationBarColor">#FAFDFB</color>

    <!-- TextInputLayout 颜色 -->
    <color name="textInputStrokeDefault">#6F7976</color>
    <color name="textInputStrokeFocused">#006B61</color>

    <!-- Dropdown 颜色 -->
    <color name="dropdownBackground">#FFFFFF</color>

    <!-- LSP 状态颜色 -->
    <color name="lspStatusConnected">#2E7D32</color>
    <color name="lspStatusDisconnected">#C62828</color>
    <color name="lspStatusInitializing">#F9A825</color>

    <!-- 按钮颜色 -->
    <color name="buttonTonalBackground">#CCE8E2</color>

    <!-- 文本颜色 -->
    <color name="textPrimary">#191C1B</color>
    <color name="textSecondary">#3F4946</color>
    <color name="textHint">#6F7976</color>

    <!-- 图标颜色 -->
    <color name="iconPrimary">#191C1B</color>
    <color name="iconSecondary">#3F4946</color>

    <!-- 分隔线颜色 -->
    <color name="divider">#DBE5E1</color>

    <!-- 高亮选择颜色 -->
    <color name="textHighlight">#40006B61</color>

    <!-- SplashScreen 图标背景色 - 与 ic_app_logo 背景色匹配 -->
    <color name="splash_icon_background">#4BA3C7</color>

    <!-- ========== 灰色主题专用颜色 ========== -->
    <!-- 灰色主题使用深灰色背景 #2D2D2D，比纯黑色更柔和，减少视觉疲劳 -->

