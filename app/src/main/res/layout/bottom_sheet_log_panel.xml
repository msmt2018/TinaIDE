<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 底部面板 -->
    <LinearLayout
        android:id="@+id/bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="?attr/colorSurface"
        android:elevation="8dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="56dp"
        app:behavior_hideable="false"
        app:behavior_fitToContents="false"
        app:behavior_halfExpandedRatio="0.5">

        <!-- 拖动手柄和工具栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="?attr/colorSurfaceVariant">

            <!-- 拖动指示器 -->
            <View
                android:id="@+id/drag_handle"
                android:layout_width="32dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:background="@drawable/bottom_sheet_drag_handle"
                android:alpha="0.4" />

            <!-- 工具栏 -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:scrollbars="none"
                android:fillViewport="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:gravity="center_vertical">

                    <!-- 编译按钮 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_compile"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="编译"
                        app:icon="@drawable/ic_play"
                        app:iconTint="?attr/colorPrimary" />

                    <!-- 停止按钮 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_stop"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="停止"
                        app:icon="@drawable/ic_stop"
                        app:iconTint="?attr/colorError" />

                    <!-- 分隔线 -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- 清空日志 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_clear_log"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="清空日志"
                        app:icon="@drawable/ic_clear"
                        app:iconTint="?attr/colorOnSurfaceVariant" />

                    <!-- 保存日志 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_save_log"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:contentDescription="保存日志"
                        app:icon="@drawable/ic_save"
                        app:iconTint="?attr/colorOnSurfaceVariant" />

                    <!-- 分隔线 -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- LSP 状态指示器 -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp">

                        <View
                            android:id="@+id/lsp_status_indicator"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/lsp_status_indicator"
                            android:backgroundTint="?attr/colorError" />

                        <TextView
                            android:id="@+id/tv_lsp_status"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="LSP 未连接"
                            android:textSize="12sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />

                    </LinearLayout>

                </LinearLayout>

            </HorizontalScrollView>

        </LinearLayout>

        <!-- 日志面板 -->
        <com.wuxianggujun.tinaide.output.LogView
            android:id="@+id/log_view"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
